#!/bin/bash

# Detectar si se usa --json antes de mostrar cualquier output
JSON_OUTPUT="false"
for arg in "$@"; do
  if [ "$arg" = "--json" ]; then
    JSON_OUTPUT="true"
    break
  fi
done
export JSON_OUTPUT

HOMEBREW_PREFIX=$(brew --prefix 2>/dev/null || echo "/usr/local")

# Detectar si estamos en Homebrew o desarrollo local
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Buscar scripts en orden de prioridad
if [ -d "$SCRIPT_DIR/scripts" ]; then
    # Desarrollo local - scripts junto al ejecutable
    scripts_dir="$SCRIPT_DIR/scripts"
elif [ -d "$HOMEBREW_PREFIX/opt/gula/scripts" ]; then
    # Instalación Homebrew (via opt symlink)
    scripts_dir="$HOMEBREW_PREFIX/opt/gula/scripts"
else
    echo "Error: No se encontró el directorio de scripts"
    echo "Buscado en:"
    echo "  - $SCRIPT_DIR/scripts (desarrollo)"
    echo "  - $HOMEBREW_PREFIX/opt/gula/scripts (homebrew)"
    echo ""
    echo "Si instalaste via Homebrew, intenta: brew reinstall gula"
    exit 1
fi

source "$scripts_dir/global_vars.sh"

# Solo mostrar logo y mensajes si no está en modo JSON
if [ "$JSON_OUTPUT" != "true" ]; then
  source "$scripts_dir/support/logo.sh"
  echo -e "  ${DIM}v${VERSION}${NC}"
fi

